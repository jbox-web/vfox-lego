#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force lego .
mise cache clear
mise install lego@4.33.0

# Capture and display the output while also verifying it
output=$(mise exec "lego@4.33.0" -- "lego" --version)
echo "lego output: ${output}"

if echo "${output}" | grep -q '4.33.0'; then
  echo "✓ Tests passed"
else
  echo "✗ Test failed: expected version lego@4.33.0"
  exit 1
fi
